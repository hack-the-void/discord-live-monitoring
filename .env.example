OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MODEL_FALLBACKS=gpt-4.1-mini,gpt-4o-mini

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
DISCORD_SUPPRESS_EMBEDS=true

TOKEN_USAGE_STATS_PATH=data/token_usage_stats.json
TOKEN_USAGE_REPORT_IN_DISCORD=true

RSS_FEEDS=https://www.technologyreview.com/feed/,https://openai.com/news/rss.xml,https://huggingface.co/blog/feed.xml

MAX_ITEMS_PER_FEED=20
MAX_CANDIDATES=60
SHORTLIST_SIZE=12

TIMEZONE=Europe/Paris
RUN_HOUR=8
RUN_MINUTE=30

CYBER_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/zzz
CYBER_DISCORD_SUPPRESS_EMBEDS=true
CYBER_DISCORD_USE_EMBEDS=true
CYBER_DISCORD_INCLUDE_ITEM_EMBEDS=false
CYBER_DISCORD_ITEM_EMBEDS_MAX=3
CYBER_SUPPRESS_INITIAL_BACKLOG=false
CYBER_RSS_FEEDS=https://nvd.nist.gov/feeds/xml/cve/misc/nvd-rss-analyzed.xml,https://www.cisa.gov/uscert/ncas/alerts.xml

CYBER_OPENAI_MODEL=gpt-4.1-mini
CYBER_OPENAI_MODEL_FALLBACKS=gpt-4.1-mini,gpt-4o-mini

CYBER_MAX_ITEMS_PER_FEED=30
CYBER_MAX_NEW_ITEMS_PER_RUN=30
CYBER_SHORTLIST_SIZE=12

CYBER_RUN_MINUTE=0

CYBER_SEEN_ITEMS_PATH=data/cyber_seen_items.json
CYBER_TOKEN_USAGE_STATS_PATH=data/cyber_token_usage_stats.json
CYBER_TOKEN_USAGE_REPORT_IN_DISCORD=true